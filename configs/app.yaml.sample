server:
  listen: "127.0.0.1:18080"

paths:
  root: "/u01/oas-admin-lite"
  data_dir: "/u01/oas-admin-lite/data"
  log_dir: "/u01/oas-admin-lite/logs"
  backup_dir: "/u01/oas-admin-lite/backups"
  bundle_dir: "/u01/oas-admin-lite/bundles"
  package_dir: "/u01/oas-admin-lite/packages"

oas:
  oracle_home: "/u01/app/oracle/product/fmw"
  domain_home: "/u01/app/oracle/config/domains/bi"
  bitools_bin: "/u01/app/oracle/config/domains/bi/bitools/bin"
  analytics_url: "https://oas.example.com/analytics"
  weblogic_console_url: "http://oas.example.com:9500/console"
  enterprise_manager_url: "http://oas.example.com:9500/em"
  # The supported OAS REST API is exposed through the web tier. In a split
  # deployment use the private/LB web-tier URL reachable from this OAS host.
  # Do not point this at an unmanaged WebLogic/BI internal listener.
  catalog_base_url: "https://bi-internal.example.com"
  catalog_api_path: "/api/20210901/catalog"
  catalog_api_url: ""
  catalog_username: ""
  catalog_password: ""

ohs:
  # false when OHS is on another Web-tier VM (the usual production layout).
  # true only when Admin Lite runs on the same VM as OHS.
  monitor_local: false
  oracle_home: "/u01/app/Oracle/Middleware/ohs_14.1.2"
  domain_home: "/u01/data/domains/ohs_domain"
  instance_name: "ohs1"
  http_port: "7777"
  https_port: ""

patch:
  allowed_patch_dirs:
    - "/u01/oas-admin-lite/packages/patches"
    - "/u01/stage/patches"

scripts:
  allowed:
    - "diagnostic_dump.sh"
    - "exportarchive.sh"
    - "runcat.sh"

security:
  username: "admin"
  password_sha256: ""
